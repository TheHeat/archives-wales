{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "slug": "black",
          "name": "Black",
          "color": "var(--color-black)"
        },
        {
          "slug": "ivory",
          "name": "Ivory",
          "color": "var(--color-ivory)"
        },
        {
          "slug": "white",
          "name": "White",
          "color": "var(--color-white)"
        },
        {
          "slug": "red",
          "name": "Red",
          "color": "var(--color-red)"
        },
        {
          "slug": "green",
          "name": "Green",
          "color": "var(--color-green)"
        },
        {
          "slug": "blue",
          "name": "Blue",
          "color": "var(--color-blue)"
        },
        {
          "slug": "blue-light",
          "name": "Blue Light",
          "color": "var(--color-blue-light)"
        },
        {
          "slug": "ground",
          "name": "Ground",
          "color": "var(--color-ground)"
        },
        {
          "slug": "surface",
          "name": "Surface",
          "color": "var(--color-surface)"
        },
        {
          "slug": "text",
          "name": "Text",
          "color": "var(--color-text)"
        }
      ]
    },
    "layout": {
      "contentSize": "48rem",
      "wideSize": "var(--length-site-max)"
    },
    "spacing": {
      "units": ["px", "em", "rem", "%", "vw", "vh"],
      "spacingSizes": [
        {
          "slug": "xs",
          "name": "XS",
          "size": "0.5em"
        },
        {
          "slug": "sm",
          "name": "SM",
          "size": "0.75em"
        },
        {
          "slug": "base",
          "name": "Base",
          "size": "1em"
        },
        {
          "slug": "lg",
          "name": "LG",
          "size": "1.5em"
        },
        {
          "slug": "xl",
          "name": "XL",
          "size": "2em"
        }
      ]
    },
    "typography": {
      "defaultFontSizes": false,
      "fontFamilies": [
        {
          "slug": "body",
          "name": "Body",
          "fontFamily": "var(--font-body)"
        },
        {
          "slug": "mono",
          "name": "Mono",
          "fontFamily": "var(--font-mono)"
        }
      ]
    },
    "custom": {
      "spacing": {
        "base": "1em",
        "spacer": "var(--length-spacer)",
        "gallery": {
          "gap": "0.5em",
          "gutter": "0.5em"
        }
      },
      "radius": {
        "default": "var(--length-border-radius)"
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--color-ground)",
      "text": "var(--color-text)"
    },
    "spacing": {
      "blockGap": "1em"
    },
    "typography": {
      "fontFamily": "var(--font-body)"
    },
    "blocks": {
      "core/gallery": {
        "spacing": {
          "blockGap": "0.5em",
          "margin": {
            "top": "0.5em",
            "bottom": "0.5em"
          }
        }
      }
    }
  }
}
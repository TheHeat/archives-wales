{
	"name": "archives-wales-theme",
	"version": "0.0.1",
	"description": "",
	"main": "src/index.js",
	"author": "Heatley & Morris",
	"license": "MIT",
	"homepage": "",
	"scripts": {
		"start": "npm run dev",
		"dev:styles": "sass src/css/index.scss:style.css --no-source-map --watch",
		"build:styles": "sass src/css/index.scss:style.css --no-source-map --style=compressed",
		"dev:js": "esbuild src/js/index.js --bundle --outfile=build/main.js --format=esm --sourcemap --watch --loader:.svg=dataurl --external:react --external:react-dom --jsx-factory=wp.element.createElement --jsx-fragment=wp.element.Fragment",
		"dev": "npm run dev:styles & npm run dev:js",
		"build:js": "esbuild src/js/index.js --bundle --outfile=build/main.js --format=esm --minify --loader:.svg=dataurl --external:react --external:react-dom --jsx-factory=wp.element.createElement --jsx-fragment=wp.element.Fragment",
		"build": "npm run build:styles && npm run build:js"
	},
	"babel": {
		"presets": [
			"@wordpress/babel-preset-default"
		],
		"plugins": [
			"@babel/plugin-proposal-class-properties"
		]
	},
	"dependencies": {
		"browser-sync": "^3.0.4",
		"fitvids": "latest",
		"formik": "^2.2.9",
		"leaflet": "^1.9.4",
		"react-cookie-consent": "^7.3.1",
		"react-file-base64": "^1.0.3",
		"react-google-recaptcha-v3": "^1.9.7",
		"react-modal": "^3.14.4",
		"react-share": "^4.4.0",
		"squishMenu": "^2.6.0"
	},
	"devDependencies": {
		"@babel/core": "^7.17.8",
		"@babel/plugin-proposal-class-properties": "^7.16.7",
		"@wordpress/babel-preset-default": "^6.6.1",
		"@wordpress/eslint-plugin": "24.0.0",
		"@wordpress/scripts": "^31.6.0",
		"esbuild": "^0.25.4",
		"sass": "^1.97.3"
	}
}
